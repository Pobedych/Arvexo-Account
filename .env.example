APP_ENV=development

# Backend
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8032
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=/api

# Database
DATABASE_URL=postgresql+psycopg://arvexo:arvexo@postgres:5432/arvexo_account

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Cookies
# In dev keep COOKIE_DOMAIN empty. Do not set Domain=localhost.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# OAuth providers are disabled until credentials are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8032/auth/google/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8032/auth/yandex/callback

TELEGRAM_BOT_TOKEN=

# Initial client
SEED_ARVEXO_STUDY_CLIENT=true
ARVEXO_STUDY_CLIENT_ID=arvexo-study
ARVEXO_STUDY_CLIENT_SECRET=dev_secret
ARVEXO_STUDY_REDIRECT_URI=http://localhost:3000/auth/callback
